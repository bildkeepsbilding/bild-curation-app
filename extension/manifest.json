{
  "manifest_version": 3,
  "name": "Bild – Sift the Web for Claude",
  "version": "1.1.0",
  "description": "Capture any page to your Bild curation app directly from the browser toolbar.",
  "permissions": ["activeTab", "storage", "cookies"],
  "host_permissions": [
    "https://*.vercel.app/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
